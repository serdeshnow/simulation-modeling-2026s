			<Events>
				<Event>
					<Id>1743595516948</Id>
					<Name><![CDATA[systemOperation]]></Name>
					<X>1000</X><Y>-170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<Id>1743495789983</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1743667200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.001]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[modelTime = time() - modelStartTime;

if ( (cafe1.size() != 0) || (cafe2.size() != 0) || (cafe3.size() != 0) || (cafe4.size() != 0) || (cafe5.size() != 0) ) {
	generalDelayTime += 0.001;
}

if (cafe1.size() != 0) {
	delayTime.set(0, delayTime.get(0) + 0.001);
}
if (cafe2.size() != 0) {
	delayTime.set(1, delayTime.get(1) + 0.001);
}
if (cafe3.size() != 0) {
	delayTime.set(2, delayTime.get(2) + 0.001);
}
if (cafe4.size() != 0) {
	delayTime.set(3, delayTime.get(3) + 0.001);
}
if (cafe5.size() != 0) {
	delayTime.set(4, delayTime.get(4) + 0.001);
}
if (cafe6.size() != 0) {
	delayTime.set(5, delayTime.get(5) + 0.001);
}]]></Action>
				</Event>
				<Event>
					<Id>1746787957231</Id>
					<Name><![CDATA[updateVar]]></Name>
					<X>1000</X><Y>-130</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<Id>1743495789982</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1743667200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[probabilSystemDowntime = 1 - generalDelayTime / modelTime;
quantitySourse = source.count();
quantityServedAgent = served.count();
quantityNotServedAgent = notServed.count();
averageAgentSystem = agentSystemStat.mean(); 
averageAgentAllQueue = agentQueueStat.mean();
averageAgentDelay = agentDelayStat.mean();
averageTimeSystem = timeSystemStat.mean();

for (int i = 0; i < m; i += 1) {
	intensService.set(i, agentService.get(i) / sumTimeService.get(i));
	systemDowntime.set(i, (modelTime - delayTime.get(i)) / modelTime);
	intensLeave.set(i, agentLeave.get(i) / modelTime);
	averageTimeService.set(i, sumTimeService.get(i) / agentService.get(i));
	averageTimeQueue.set(i, sumTimeQueue.get(i) / agentQueue.get(i));
}

sumBusyChannels.set(0, sumBusyChannels.get(0) + cafe1.size());
sumBusyChannels.set(1, sumBusyChannels.get(1) + cafe2.size());
sumBusyChannels.set(2, sumBusyChannels.get(2) + cafe3.size());
sumBusyChannels.set(3, sumBusyChannels.get(3) + cafe4.size());
sumBusyChannels.set(4, sumBusyChannels.get(4) + cafe5.size());
sumBusyChannels.set(5, sumBusyChannels.get(5) + cafe6.size());

for (int i = 0; i < m; i += 1) {
	averageBusyChannels.set(i, sumBusyChannels.get(i) / modelTime);
}

sumAgentsQueue.set(0, sumAgentsQueue.get(0) + queue1Cafe1.size() + queue2Cafe1.size());
sumAgentsQueue.set(1, sumAgentsQueue.get(1) + queue1Cafe2.size() + queue2Cafe2.size());
sumAgentsQueue.set(2, sumAgentsQueue.get(2) + queue1Cafe3.size() + queue2Cafe3.size());
sumAgentsQueue.set(3, sumAgentsQueue.get(3) + queue1Cafe4.size() + queue2Cafe4.size());
sumAgentsQueue.set(4, sumAgentsQueue.get(4) + queue1Cafe5.size() + queue2Cafe5.size());
sumAgentsQueue.set(5, sumAgentsQueue.get(5) + queue1Cafe6.size() + queue2Cafe6.size());

double sum = 0.0;
for (int i = 0; i < m; i += 1) {
	averageAgentQueue.set(i, sumAgentsQueue.get(i) / modelTime);
	
	if (averageTimeQueue.get(i) > 0) { 
		averTimeInCafe.set(i, averageTimeQueue.get(i));
	}
	sum += sumTimeService.get(i);
}
if (quantityServedAgent > 0) { 
	averTimeInDelay = sum / quantityServedAgent; 
}
]]></Action>
				</Event>
