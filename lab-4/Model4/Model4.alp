					<Action><![CDATA[countInCafe.set(0, count(clients, c -> c.currentState.equals("cafe1")));
countInCafe.set(1, count(clients, c -> c.currentState.equals("cafe2")));
countInCafe.set(2, count(clients, c -> c.currentState.equals("cafe3")));
countInCafe.set(3, count(clients, c -> c.currentState.equals("cafe4")));
countInCafe.set(4, count(clients, c -> c.currentState.equals("cafe5")));
countInCafe.set(5, count(clients, c -> c.currentState.equals("cafe6")));
countInDelay = count(clients, c -> c.currentState.equals("delay"));


]]></Action>
