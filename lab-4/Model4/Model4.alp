			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[SelectOutputOut]]></ReturnType>
					<Id>1743501696559</Id>
					<Name><![CDATA[сhooseOutput]]></Name>
					<X>620</X><Y>-80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[agent]]></Name>
						<Type><![CDATA[Client]]></Type>
					</Parameter>
					<Body><![CDATA[if (agent.numАttempts < 0) {
	return outputNotServed;
}
else {
	agent.numАttempts -= 1;
}

ArrayList queues = new ArrayList<Integer>();
queues.add(queue1Cafe1.size() + queue2Cafe1.size());
queues.add(queue1Cafe2.size() + queue2Cafe2.size());
queues.add(queue1Cafe3.size() + queue2Cafe3.size());
queues.add(queue1Cafe4.size() + queue2Cafe4.size());
queues.add(queue1Cafe5.size() + queue2Cafe5.size());
queues.add(queue1Cafe6.size() + queue2Cafe6.size());

int minQueueIndex = queues.indexOf(Collections.min(queues));
int minValue = (int)queues.get(minQueueIndex);
ArrayList minQueues = new ArrayList<Integer>();

for (int i = 0; i < queues.size(); i++) {
	if (minValue == (int)queues.get(i)) {
		minQueues.add(i);
	}
}

int randIndex = (new Random()).nextInt(minQueues.size());

int index = (int)minQueues.get(randIndex);
switch(index) {
	case 0:
		return outputCafe1;
	case 1:
		return outputCafe2;
	case 2:
		return outputCafe3;
	case 3:
		return outputCafe4;
	case 4:
		return outputCafe5;
	case 5:
		return outputCafe6;
}
return null;]]></Body>
				</Function>
			</Functions>
