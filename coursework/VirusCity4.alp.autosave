				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779009160719</Id>
					<Name><![CDATA[receiveInfection]]></Name>
					<X>30</X><Y>600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[place]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Body><![CDATA[if (healthState == 0 && !everInfected) {
    everInfected = true;
    infectionPlace = place;
    
if (place == 0) {
    ((Main)get_Main()).homeInfections++;
} else if (place == 1) {
    ((Main)get_Main()).workInfections++;
} else if (place == 2) {
    ((Main)get_Main()).walkInfections++;
} else if (place == 3) {
    ((Main)get_Main()).canteenInfections++;
}
    
    statechart.fireEvent("infect");
//    infectionFlag = true;
//    healthStatechart.onChange();
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779009192335</Id>
					<Name><![CDATA[forceInitialInfection]]></Name>
					<X>30</X><Y>520</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (healthState == 0 && !everInfected) {
    everInfected = true;
    infectionPlace = -1;
    statechart.fireEvent("infect");
//    infectionFlag = true;
//    healthStatechart.onChange();
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779009192358</Id>
					<Name><![CDATA[placeAtHome]]></Name>
					<X>410</X><Y>640</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[currentLocation = 0;

// Один раз выбираем постоянную точку дома для конкретного агента.
// Дальше агент всегда возвращается именно туда.
if (homeX < 0 || homeY < 0) {
    initHomePosition();
}

setXY(homeX, homeY);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779009214047</Id>
					<Name><![CDATA[placeAtWork]]></Name>
					<X>410</X><Y>680</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[currentLocation = 1;
setXY(uniform(300, 700), uniform(190, 430));]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1779009214073</Id>
					<Name><![CDATA[shouldGoToWork]]></Name>
					<X>210</X><Y>680</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[Main m = (Main)get_Main();

if (healthState == 5) {
    return false;
}

// Симптомный больной может остаться дома
if (healthState == 2 && symptomaticStaysHome) {
    return false;
}

// Карантин с 30-го дня:
// на работу ходят только бессимптомные, потому что они не знают о болезни
if (m.quarantineEnabled && time() >= m.quarantineStartDay * 24) {
    return healthState == 4 || healthState == 3 || healthState == 1 || healthState == 0;
}

return true;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779009214084</Id>
					<Name><![CDATA[updateDailyLocation]]></Name>
					<X>30</X><Y>680</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[hour]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Body><![CDATA[if (healthState == 5) {
    return;
}

// Столовая с 13:00 до 14:00.
// Все живые жители идут туда независимо от того,
// должны они быть дома, на работе или на прогулке.
if (hour >= 13 && hour < 14) {
    placeAtCanteen();
    return;
}

// Симптомные больные, которые решили остаться дома,
// не ходят ни на работу, ни гулять.
if (healthState == 2 && symptomaticStaysHome) {
    placeAtHome();
    return;
}

// День 0 считаем понедельником:
// 0 - пн, 1 - вт, 2 - ср, 3 - чт, 4 - пт, 5 - сб, 6 - вс.
int day = (int)Math.floor(time() / 24.0);
int dayOfWeek = day % 7;
boolean isWeekend = dayOfWeek == 5 || dayOfWeek == 6;

// Выходные: не работаем, гуляем с 10:00 до 18:00.
if (isWeekend) {
    if (hour >= 10 && hour < 18) {
        placeOutside();
    } else {
        placeAtHome();
    }
    return;
}

// Будни: работа только с 9:00 до 18:00.
if (hour >= 9 && hour < 18 && shouldGoToWork()) {
    placeAtWork();
    return;
}

// Будний вечер: прогулка с 18:00 до 22:00.
// Если прогулка нужна только по выходным, удали этот блок.
if (hour >= 18 && hour < 22) {
    placeOutside();
    return;
}

// Остальное время агент находится дома.
placeAtHome();]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779009214091</Id>
					<Name><![CDATA[tryInfectNeighbors]]></Name>
					<X>30</X><Y>640</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[Main m = (Main)get_Main();

if (!isInfectious()) {
    return;
}

double transmissionProbability = healthState == 3
        ? m.asymptomaticTransmissionProbability
        : m.symptomaticTransmissionProbability;

for (int i = 0; i < m.population.size(); i++) {
    Person other = m.population.get(i);

    if (other == this) {
        continue;
    }

    if (other.healthState != 0) {
        continue;
    }

    if (other.currentLocation != currentLocation) {
        continue;
    }

    double dx = getX() - other.getX();
    double dy = getY() - other.getY();
    double distance = Math.sqrt(dx * dx + dy * dy);

    if (distance <= m.infectionRadius && randomTrue(transmissionProbability)) {
        other.receiveInfection(currentLocation);
    }
}]]></Body>
				</Function>
